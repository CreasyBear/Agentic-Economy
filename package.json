{
  "name": "agentic-economy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev --host 127.0.0.1",
    "build": "vite build",
    "start": "vite start",
    "typecheck": "tsc --noEmit",
    "check:convex-codegen": "convex codegen --dry-run --typecheck=disable",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test tests/e2e",
    "test:deploy-smoke": "playwright test --config=playwright.deploy-smoke.config.ts tests/deploy-smoke/phase1-deploy-smoke.spec.ts",
    "test:phase2-support-smoke": "playwright test --config=playwright.deploy-smoke.config.ts tests/deploy-smoke/phase2-support-record-smoke.spec.ts",
    "test:provider-smoke:resend": "playwright test --config=playwright.deploy-smoke.config.ts tests/deploy-smoke/phase2-resend-dispatch-smoke.spec.ts",
    "test:provider-smoke:novu": "playwright test --config=playwright.deploy-smoke.config.ts tests/deploy-smoke/phase2-novu-dispatch-smoke.spec.ts",
    "test:provider-smoke:autumn-stripe": "playwright test --config=playwright.deploy-smoke.config.ts tests/deploy-smoke/phase5-paid-activation-provider-smoke.spec.ts",
    "test:e2e:a11y": "playwright test tests/e2e/a11y",
    "test:a11y": "playwright test tests/e2e/a11y",
    "test:types": "vitest run tests/types",
    "test:imports": "AE_SCAN_MODE=clean vitest run tests/imports/backup-imports.test.ts tests/imports/private-imports.test.ts tests/imports/route-boundary.test.ts",
    "test:imports:fixtures": "AE_SCAN_MODE=fixtures vitest run tests/imports/backup-imports.test.ts tests/imports/private-imports.test.ts tests/imports/route-boundary.test.ts",
    "test:source-mining": "AE_SCAN_MODE=clean vitest run tests/imports/source-mining.test.ts",
    "test:source-mining:fixtures": "AE_SCAN_MODE=fixtures vitest run tests/imports/source-mining.test.ts",
    "test:ts-standards": "AE_SCAN_MODE=clean vitest run tests/imports/ts-standards.test.ts",
    "test:ts-standards:fixtures": "AE_SCAN_MODE=fixtures vitest run tests/imports/ts-standards.test.ts",
    "test:copy": "AE_SCAN_MODE=clean vitest run tests/copy",
    "test:copy:fixtures": "AE_SCAN_MODE=fixtures vitest run tests/copy",
    "test:seo": "vitest run tests/seo",
    "test:ui-contract": "AE_SCAN_MODE=clean vitest run tests/ui-contract",
    "test:ui-contract:fixtures": "AE_SCAN_MODE=fixtures vitest run tests/ui-contract",
    "test:all": "npm run typecheck && npm run check:convex-codegen && npm run test:unit && npm run test:integration && npm run test:types && npm run test:imports && npm run test:source-mining && npm run test:ts-standards && npm run test:copy && npm run test:seo && npm run test:ui-contract && npm run build"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "1.4.9",
    "@fontsource-variable/geist": "^5.2.9",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-start": "1.168.26",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "convex": "1.42.0",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.12.0",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.10.2",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "nitro": "npm:nitro-nightly@^3.0.1-20260628-090458-3df69609",
    "tailwindcss": "^4.3.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.9"
  },
  "packageManager": "npm@11.5.1"
}
